generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String                 @id @default(uuid()) @db.Uuid   
  email      String                 @unique 
  name       String?
  createAt   DateTime               @default(now())
  orders     Order[]
}

model Order {
  id            String    @id @default(uuid()) @db.Uuid
  item         String    
  quanity      Int        @default(1)
  userId       String     @db.Uuid
  user         User       @relation(fields : [userId], references : [id])
  createAt     DateTime   @default(now())
}